generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tracking {
  id              String   @id @default(uuid())
  slug            String
  trackingNumber  String
  status          String
  statusDetail    String?
  checkpoints     Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([slug, trackingNumber])
}